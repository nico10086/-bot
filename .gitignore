# ── 密钥与凭证（敏感信息） ──
.env
.env.local
.env.*.local

# ── Python 虚拟环境 ──
env/
.env/
venv/
.venv/

# ── Python 缓存 ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
*.so
*.pyd

# ── NapCat 缓存与运行时数据 ──
NapCat.Shell/cache/
NapCat.Shell/logs/
NapCat.Shell/*.db
NapCat.Shell/data/
NapCat.Shell/worker/
NapCat.Shell/conout-*.js
NapCat.Shell/loadNapCat.js
NapCat.Shell/KillQQ.bat
NapCat.Shell/quickLoginExample.bat

# ── NapCat 依赖与原生二进制 ──
NapCat.Shell/node_modules/
NapCat.Shell/native/

# ── NapCat WebUI 静态文件 ──
NapCat.Shell/static/

# ── NapCat 配置（含 QQ 号或 token 的敏感配置） ──
NapCat.Shell/config/webui.json
NapCat.Shell/config/napcat_*.json
NapCat.Shell/config/onebot11_*.json
NapCat.Shell/config/napcat_protocol_*.json

# ── 数据库文件 ──
*.db
*.sqlite
*.sqlite3

# ── IDE / 编辑器 ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── 系统文件 ──
desktop.ini
