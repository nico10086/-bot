# 🐱 猫娘 Bot - 环境配置模板
# 复制此文件为 .env，填入你的配置

# DeepSeek API Key（必填）
# 在 https://platform.deepseek.com 注册获取
DEEPSEEK_API_KEY=sk-你的密钥

# Bot 在群聊中的触发词（可选）
# 当群聊中 @不生效时，提到这个名字也会触发回复
BOT_NAME=猫娘

# 性格（可选：catgirl / tsundere）
BOT_PERSONALITY=catgirl

# 温度参数（可选，0~1）
temperature=0.7

# ── 以下配置可通过桌面版 UI 自动管理，无需手动编辑 ──
# MODEL_PROVIDER=deepseek
# MODEL_NAME=deepseek-chat
# API_KEY=sk-...
# SELECTED_MODEL=test
# BOT_PERSONALITY=catgirl
